#version 450

layout(local_size_x = 64) in;

layout(set = 0, binding = 0) readonly buffer InBuf {
    float in_data[];
};

layout(set = 0, binding = 1) writeonly buffer OutBuf {
    float out_data[];
};

layout(push_constant) uniform Params {
    uint count;
};

void main() {
    uint idx = gl_GlobalInvocationID.x;
    if (idx >= count) return;
    out_data[idx] = in_data[idx] * 2.0;
}
